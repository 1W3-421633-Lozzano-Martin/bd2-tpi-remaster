{
  "$schema": "https://railway.app/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish -c Release",
    "startCommand": "dotnet WatchParty.Backend.dll"
  },
  "deploy": {
    "region": "us-east1",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "variables": {
    "ASPNETCORE_ENVIRONMENT": "Production",
    "PORT": "8080"
  }
}
